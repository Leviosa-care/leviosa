# Copy to .env and fill in. Used by `make local-up` / `make local-down` (local.compose.yaml).

APP_ENV=local
PORT=3000
BACKEND_PORT=3500

# Postgres (defaults below match local.compose.yaml's fallback values)
POSTGRES_DB=leviosa
POSTGRES_USER=user
POSTGRES_PASSWORD=password

# Redis
REDIS_PASSWORD=secret
REDIS_DB=0

# RabbitMQ (defaults below match local.compose.yaml's fallback values)
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# AWS S3
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
BUCKETNAME=

# Stripe
STRIPE_SECRET_KEY=

# Gmail SMTP
GMAIL_EMAIL=
GMAIL_PASSWORD=
