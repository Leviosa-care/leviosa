# Leviosa Terraform Variables Example
# Copy to terraform.tfvars.staging or terraform.tfvars.production and fill in values

aws_region   = "eu-central-1"
project_name = "leviosa"
environment  = "staging"

# ============================================
# Hetzner Cloud
# ============================================

hcloud_token    = "your_hetzner_api_token_here"
server_type     = "cpx11"
server_location = "nbg1"
enable_backups  = true

# ============================================
# Cloudflare DNS
# ============================================

cloudflare_token = "your_cloudflare_api_token_here"
zone_id          = "your_zone_id_here"
domain_name      = "leviosa.care"

# ============================================
# CORS
# ============================================

allowed_origins = [
  "http://localhost:5173",
  "https://leviosa.care",
  "https://staging.leviosa.care",
]
