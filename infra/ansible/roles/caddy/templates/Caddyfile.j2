# Caddyfile - Managed by Ansible - DO NOT EDIT MANUALLY
# Generated: {{ ansible_date_time.iso8601 }}

{
        servers {
                # Trust Cloudflare proxy IPs for X-Forwarded-For headers
                trusted_proxies static 173.245.48.0/20 103.21.244.0/22 103.22.200.0/22 103.31.4.0/22 141.101.64.0/18 108.162.192.0/18 190.93.240.0/20 188.114.96.0/20 197.234.240.0/22 198.41.128.0/17 162.158.0.0/15 104.16.0.0/13 104.24.0.0/14 172.64.0.0/13 131.0.72.0/22
        }
}


# ============================================
# Production sites
# ============================================

leviosa.care, www.leviosa.care {
        tls {
                dns cloudflare {env.CLOUDFLARE_API_TOKEN}
        }

        reverse_proxy {{ app_name }}_frontend:{{ frontend_port | default('3000') }}

        # Security headers
        header {
                Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
                X-Content-Type-Options "nosniff"
                X-Frame-Options "SAMEORIGIN"
                X-XSS-Protection "1; mode=block"
                Referrer-Policy "strict-origin-when-cross-origin"
                -Server
        }

        request_body {
                max_size 100M
        }

        log {
                output file /var/log/caddy/access.log {
                        roll_size 100mb
                        roll_keep 5
                        roll_keep_for 720h
                }
                format json
        }
}

# ============================================
# Staging sites
# ============================================

staging.leviosa.care, www.staging.leviosa.care {
        tls {
                dns cloudflare {env.CLOUDFLARE_API_TOKEN}
        }

        reverse_proxy {{ app_name }}_staging_frontend:{{ frontend_port | default('3000') }}

{% if caddy_basic_auth_username | default('') != '' %}
        basicauth / {
                {{ caddy_basic_auth_username }} {{ caddy_basic_auth_password_hash }}
        }
{% endif %}

        header {
                Strict-Transport-Security "max-age=31536000; includeSubDomains"
                X-Content-Type-Options "nosniff"
                X-Frame-Options "DENY"
                X-XSS-Protection "1; mode=block"
                Referrer-Policy "strict-origin-when-cross-origin"
                -Server
        }

        request_body {
                max_size 100M
        }

        log {
                output file /var/log/caddy/staging-access.log {
                        roll_size 100mb
                        roll_keep 5
                        roll_keep_for 720h
                }
                format json
        }
}
