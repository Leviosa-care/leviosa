# ============================================
# Production sites
# ============================================

leviosa.care, www.leviosa.care {
        reverse_proxy localhost:3000

        # Security headers
        header {
                # HSTS
                Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"

                # Prevent MIME type sniffing
                X-Content-Type-Options "nosniff"

                # Prevent clickjacking
                X-Frame-Options "SAMEORIGIN"

                # XSS protection
                X-XSS-Protection "1; mode=block"

                # Referrer policy
                Referrer-Policy "strict-origin-when-cross-origin"

                # Remove server header
                -Server
        }

        # Client upload size limit
        request_body {
                max_size 100M
        }

        # JSON access logs for fail2ban
        log {
                output file /var/log/caddy/access.log {
                        roll_size 100mb
                        roll_keep 5
                        roll_keep_for 720h
                }
                format json
        }
}

# ============================================
# Staging sites with basic auth
# ============================================

staging.leviosa.care, www.staging.leviosa.care {
        reverse_proxy localhost:3001
        basicauth / {
                {{ caddy_basic_auth_username }} {{ caddy_basic_auth_password_hash }}
        }

        # Security headers
        header {
                Strict-Transport-Security "max-age=31536000; includeSubDomains"
                X-Content-Type-Options "nosniff"
                X-Frame-Options "DENY"
                X-XSS-Protection "1; mode=block"
                Referrer-Policy "strict-origin-when-cross-origin"
                -Server
        }

        request_body {
                max_size 100M
        }

        # JSON access logs for fail2ban
        log {
                output file /var/log/caddy/staging-access.log {
                        roll_size 100mb
                        roll_keep 5
                        roll_keep_for 720h
                }
                format json
        }
}
