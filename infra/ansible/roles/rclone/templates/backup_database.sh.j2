#!/bin/bash

# Leviosa Local and Remote Backup Script

export PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin

# Configuration
USER="{{ user }}"
BACKUP_DIR="{{ rclone_backup_dir }}"
VOLUME_NAME="production_backend_data"
TIMESTAMP=$(date +"%Y%m%d_%H%M%S")
BACKUP_FILE="leviosa_backup_$TIMESTAMP.tar.gz"
RETENTION_DAYS=7
GPG_RECIPIENT="{{ gpg_recipient }}"
LOG_FILE="$BACKUP_DIR/backup.log"

REMOTE_NAME="{{ rclone_aws_remote_name }}"
REMOTE_PATH="{{ rclone_aws_bucket_name }}/backups"
REMOTE_RETENTION_DAYS=30

# Exit on error
set -e

# Create backup directory if it doesn't exist
mkdir -p $BACKUP_DIR
chown -R $USER:$USER $BACKUP_DIR

# Logging
exec > >(tee -a $LOG_FILE) 2>&1
echo "[$(date)] Backup started."

# Stop leviosa containers
echo "[$(date)] Stopping leviosa related production containers..."
docker ps -a --format {% raw %}{{.Names}}{% endraw %} | grep "^production-" | xargs -r docker stop
# TODO: I need to find a way to do some sort of graceful shutdown of the application so that the user are notified that they can not use the application for some time
# use the sigterm signal to the application to see what it does ?

# Get the Docker volume path
VOLUME_PATH=$(docker volume inspect -f {% raw %}'{{ .Mountpoint }}'{% endraw %} $VOLUME_NAME)

# Create a tar.gz of the entire data directory
echo "[$(date)] Creating tar.gz archive..."
if ! tar -czf $BACKUP_DIR/$BACKUP_FILE -C $VOLUME_PATH .; then
  echo "[$(date)] Error: Failed to create tar.gz archive."
  docker ps -a --format {% raw %}{{.Names}}{% endraw %} | grep "^production-" | xargs -r docker start
  exit 1
fi

# Verify the integrity of the tar.gz archive
echo "[$(date)] Verifying tar.gz archive integrity..."
if ! tar -tzf $BACKUP_DIR/$BACKUP_FILE > /dev/null; then
  echo "[$(date)] Error: tar.gz archive is corrupted."
  docker ps -a --format {% raw %}{{.Names}}{% endraw %} | grep "^production-" | xargs -r docker start
  exit 1
fi

# Start containers
echo "[$(date)] Starting containers..."
docker ps -a --format {% raw %}{{.Names}}{% endraw %} | grep "^production-" | xargs -r docker start

# Encrypt backup
echo "[$(date)] Encrypting backup..."
if ! gpg --encrypt --recipient $GPG_RECIPIENT $BACKUP_DIR/$BACKUP_FILE; then
  echo "[$(date)] Error: GPG encryption failed."
  exit 1
fi

# Delete the unencrypted backup file
echo "[$(date)] Deleting unencrypted backup file..."
rm -f $BACKUP_DIR/$BACKUP_FILE

# Delete backups older than RETENTION_DAYS
echo "[$(date)] Removing backups older than $RETENTION_DAYS days..."
find $BACKUP_DIR -name "leviosa_backup_*.tar.gz.gpg" -type f -mtime +$RETENTION_DAYS -delete

echo "[$(date)] Local backup completed: $BACKUP_DIR/$BACKUP_FILE.gpg"

# Find the most recent backup file
LATEST_BACKUP=$(ls -t $BACKUP_DIR/leviosa_backup_*.tar.gz.gpg | head -1)

if [ -z "$LATEST_BACKUP" ]; then
  echo "[$(date)] Error: No backup files found in $BACKUP_DIR"
  exit 1
fi

# Copy to remote storage
echo "[$(date)] Copying latest backup to remote storage: $LATEST_BACKUP"
rclone copy "$LATEST_BACKUP" $REMOTE_NAME:$REMOTE_PATH/ --s3-region eu-central-1 --s3-location-constraint eu-central-1 --s3-no-check-bucket
if [ $? -ne 0 ]; then
  echo "[$(date)] Error: Failed to copy backup to remote storage."
  exit 1
fi

# Clean up old backups in remote storage
echo "[$(date)] Cleaning up old backups in remote storage..."
rclone delete $REMOTE_NAME:$REMOTE_PATH/ --min-age ${REMOTE_RETENTION_DAYS}d

echo "[$(date)] Offsite backup completed."
