#!/bin/bash

# Leviosa Local and Remote Backup Script

export PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin

# Configuration
USER="{{ deploy_user }}"
BACKUP_DIR="{{ rclone_backup_dir }}"
VOLUME_NAME="production_backend_data"
VAULT_DATA_DIR="{{ app_data_dir }}/vault"
TIMESTAMP=$(date +"%Y%m%d_%H%M%S")
BACKUP_FILE="leviosa_backup_$TIMESTAMP.tar.gz"
VAULT_BACKUP_FILE="leviosa_vault_$TIMESTAMP.tar.gz"
RETENTION_DAYS=7
GPG_RECIPIENT="{{ gpg_recipient }}"
LOG_FILE="$BACKUP_DIR/backup.log"

REMOTE_NAME="{{ rclone_aws_remote_name }}"
REMOTE_PATH="{{ rclone_aws_bucket_name }}/backups"
REMOTE_RETENTION_DAYS=30

# Exit on error
set -e

# Create backup directory if it doesn't exist
mkdir -p $BACKUP_DIR
chown -R $USER:$USER $BACKUP_DIR

# Logging
exec > >(tee -a $LOG_FILE) 2>&1
echo "[$(date)] Backup started."

# Stop leviosa containers
echo "[$(date)] Stopping leviosa related production containers..."
docker ps -a --format {% raw %}{{.Names}}{% endraw %} | grep "^production-" | xargs -r docker stop

# Get the Docker volume path
VOLUME_PATH=$(docker volume inspect -f {% raw %}'{{ .Mountpoint }}'{% endraw %} $VOLUME_NAME)

# Create a tar.gz of the entire data directory
echo "[$(date)] Creating database archive..."
if ! tar -czf $BACKUP_DIR/$BACKUP_FILE -C $VOLUME_PATH .; then
  echo "[$(date)] Error: Failed to create database archive."
  docker ps -a --format {% raw %}{{.Names}}{% endraw %} | grep "^production-" | xargs -r docker start
  exit 1
fi

# Verify the integrity of the tar.gz archive
echo "[$(date)] Verifying database archive integrity..."
if ! tar -tzf $BACKUP_DIR/$BACKUP_FILE > /dev/null; then
  echo "[$(date)] Error: Database archive is corrupted."
  docker ps -a --format {% raw %}{{.Names}}{% endraw %} | grep "^production-" | xargs -r docker start
  exit 1
fi

# Create a tar.gz of the vault data directory (while containers are stopped for consistency)
echo "[$(date)] Creating vault archive..."
if ! tar -czf $BACKUP_DIR/$VAULT_BACKUP_FILE -C $VAULT_DATA_DIR .; then
  echo "[$(date)] Error: Failed to create vault archive."
  docker ps -a --format {% raw %}{{.Names}}{% endraw %} | grep "^production-" | xargs -r docker start
  exit 1
fi

echo "[$(date)] Verifying vault archive integrity..."
if ! tar -tzf $BACKUP_DIR/$VAULT_BACKUP_FILE > /dev/null; then
  echo "[$(date)] Error: Vault archive is corrupted."
  docker ps -a --format {% raw %}{{.Names}}{% endraw %} | grep "^production-" | xargs -r docker start
  exit 1
fi

# Start containers
echo "[$(date)] Starting containers..."
docker ps -a --format {% raw %}{{.Names}}{% endraw %} | grep "^production-" | xargs -r docker start

# Encrypt database backup
echo "[$(date)] Encrypting database backup..."
if ! gpg --encrypt --recipient $GPG_RECIPIENT $BACKUP_DIR/$BACKUP_FILE; then
  echo "[$(date)] Error: GPG encryption of database backup failed."
  exit 1
fi
rm -f $BACKUP_DIR/$BACKUP_FILE

# Encrypt vault backup
echo "[$(date)] Encrypting vault backup..."
if ! gpg --encrypt --recipient $GPG_RECIPIENT $BACKUP_DIR/$VAULT_BACKUP_FILE; then
  echo "[$(date)] Error: GPG encryption of vault backup failed."
  exit 1
fi
rm -f $BACKUP_DIR/$VAULT_BACKUP_FILE

# Delete local backups older than RETENTION_DAYS
echo "[$(date)] Removing local backups older than $RETENTION_DAYS days..."
find $BACKUP_DIR -name "leviosa_backup_*.tar.gz.gpg" -type f -mtime +$RETENTION_DAYS -delete
find $BACKUP_DIR -name "leviosa_vault_*.tar.gz.gpg" -type f -mtime +$RETENTION_DAYS -delete

# Upload database backup to S3
LATEST_DB_BACKUP=$(ls -t $BACKUP_DIR/leviosa_backup_*.tar.gz.gpg 2>/dev/null | head -1)
if [ -z "$LATEST_DB_BACKUP" ]; then
  echo "[$(date)] Error: No database backup file found in $BACKUP_DIR"
  exit 1
fi
echo "[$(date)] Uploading database backup to S3: $LATEST_DB_BACKUP"
rclone copy "$LATEST_DB_BACKUP" $REMOTE_NAME:$REMOTE_PATH/ --s3-region eu-central-1 --s3-location-constraint eu-central-1 --s3-no-check-bucket

# Upload vault backup to S3
LATEST_VAULT_BACKUP=$(ls -t $BACKUP_DIR/leviosa_vault_*.tar.gz.gpg 2>/dev/null | head -1)
if [ -z "$LATEST_VAULT_BACKUP" ]; then
  echo "[$(date)] Error: No vault backup file found in $BACKUP_DIR"
  exit 1
fi
echo "[$(date)] Uploading vault backup to S3: $LATEST_VAULT_BACKUP"
rclone copy "$LATEST_VAULT_BACKUP" $REMOTE_NAME:$REMOTE_PATH/ --s3-region eu-central-1 --s3-location-constraint eu-central-1 --s3-no-check-bucket

# Clean up old S3 backups
echo "[$(date)] Cleaning up old backups in remote storage..."
rclone delete $REMOTE_NAME:$REMOTE_PATH/ --include "leviosa_backup_*.tar.gz.gpg" --min-age ${REMOTE_RETENTION_DAYS}d
rclone delete $REMOTE_NAME:$REMOTE_PATH/ --include "leviosa_vault_*.tar.gz.gpg" --min-age ${REMOTE_RETENTION_DAYS}d

echo "[$(date)] Backup complete. DB: $LATEST_DB_BACKUP  Vault: $LATEST_VAULT_BACKUP"
