# Leviosa Environment Configuration
# Managed by Ansible - DO NOT EDIT MANUALLY
# Generated: {{ ansible_date_time.iso8601 }}

# ============================================
# Application Configuration
# ============================================
NODE_ENV=production
APP_PORT={{ app_port | default('3000') }}
APP_URL=https://{{ app_domain }}
APP_ENV={{ app_env | default('production') }}

# ============================================
# Backend Configuration
# ============================================
BACKEND_PORT={{ backend_port | default('3500') }}
BACKEND_URL=http://backend:{{ backend_port | default('3500') }}

# ============================================
# Database Configuration
# ============================================
{% if use_shared_services | default(false) %}
# Staging: connect to prod's postgres container by container name
DATABASE_URL=postgresql://{{ db_user | default('leviosa') }}:{{ db_password | default('change_me') | urlencode }}@leviosa_postgres:5432/{{ db_name | default('leviosa_staging') }}
{% else %}
DATABASE_URL=postgresql://{{ db_user | default('leviosa') }}:{{ db_password | default('change_me') | urlencode }}@postgres:5432/{{ db_name | default('leviosa') }}
POSTGRES_USER={{ db_user | default('leviosa') }}
POSTGRES_PASSWORD={{ db_password | default('change_me') }}
POSTGRES_DB={{ db_name | default('leviosa') }}
{% endif %}

# ============================================
# Redis Configuration
# ============================================
{% if use_shared_services | default(false) %}
# Staging: connect to prod's redis container by container name, use DB index {{ redis_db | default(1) }}
REDIS_HOST=leviosa_redis
REDIS_PORT=6379
REDIS_DB={{ redis_db | default(1) }}
{% else %}
REDIS_HOST=redis
REDIS_PORT=6379
{% endif %}
REDIS_PASSWORD={{ redis_password | default('') }}
REDIS_ADDR={{ redis_addr | default('redis:6379') }}

# ============================================
# Session Configuration
# ============================================
SESSION_SECRET={{ session_secret | default('change_me_to_random_string') }}

# ============================================
# AWS Configuration (S3)
# ============================================
S3_BUCKET={{ app_env_vars.S3_BUCKET | default('') }}
S3_BUCKET_NAME={{ app_env_vars.S3_BUCKET | default('') }}
S3_REGION={{ app_env_vars.S3_REGION | default('eu-central-1') }}
S3_PUBLIC_URL={{ app_env_vars.S3_PUBLIC_URL | default('https://' + app_env_vars.S3_BUCKET | default('') + '.s3.' + app_env_vars.S3_REGION | default('eu-central-1') + '.amazonaws.com') }}
AWS_ACCESS_KEY_ID={{ app_env_vars.AWS_ACCESS_KEY_ID | default('') }}
AWS_SECRET_ACCESS_KEY={{ app_env_vars.AWS_SECRET_ACCESS_KEY | default('') }}
AWS_REGION={{ app_env_vars.AWS_REGION | default('eu-central-1') }}

# ============================================
# CloudFront CDN Configuration
# ============================================
CLOUDFRONT_DOMAIN={{ app_env_vars.CLOUDFRONT_DOMAIN | default('') }}
MEDIA_URL={{ app_env_vars.MEDIA_URL | default('') }}

# ============================================
# Email Configuration (Gmail SMTP or AWS SES)
# ============================================
{% if app_env_vars.SMTP_HOST is defined %}
SMTP_HOST={{ app_env_vars.SMTP_HOST }}
SMTP_PORT={{ app_env_vars.SMTP_PORT | default('587') }}
SMTP_SECURE={{ app_env_vars.SMTP_SECURE | default('false') }}
SMTP_USER={{ app_env_vars.SMTP_USER | default('') }}
SMTP_PASSWORD={{ app_env_vars.SMTP_PASSWORD | default('') }}
{% endif %}
SMTP_FROM_EMAIL={{ app_env_vars.SMTP_FROM_EMAIL | default('noreply@' + app_domain) }}
SMTP_FROM_NAME={{ app_env_vars.SMTP_FROM_NAME | default('Leviosa') }}

# ============================================
# Contact Email
# ============================================
CONTACT_EMAIL={{ app_env_vars.CONTACT_EMAIL | default('contact@' + app_domain) }}

# ============================================
# Public URL Configuration
# ============================================
PUBLIC_URL={{ app_env_vars.PUBLIC_URL | default('https://' + app_domain) }}

# ============================================
# File Upload Configuration
# ============================================
MAX_FILE_SIZE={{ app_env_vars.MAX_FILE_SIZE | default('10485760') }}
ALLOWED_IMAGE_TYPES={{ app_env_vars.ALLOWED_IMAGE_TYPES | default('image/jpeg,image/png,image/webp,image/gif') }}
ALLOWED_VIDEO_TYPES={{ app_env_vars.ALLOWED_VIDEO_TYPES | default('video/mp4,video/webm,video/quicktime') }}

# ============================================
# Stripe Configuration
# ============================================
STRIPE_SECRET_KEY={{ app_env_vars.STRIPE_SECRET_KEY | default('') }}
STRIPE_WEBHOOK_SECRET={{ app_env_vars.STRIPE_WEBHOOK_SECRET | default('') }}
STRIPE_PUBLISHABLE_KEY={{ app_env_vars.STRIPE_PUBLISHABLE_KEY | default('') }}

# ============================================
# Cron Security (required in production, min 32 characters)
# ============================================
CRON_SECRET={{ app_env_vars.CRON_SECRET | default('change-me-to-a-secure-random-string-min-32-chars') }}

# ============================================
# Google OAuth Configuration (Optional)
# ============================================
GOOGLE_CLIENT_ID={{ app_env_vars.GOOGLE_CLIENT_ID | default('') }}
GOOGLE_CLIENT_SECRET={{ app_env_vars.GOOGLE_CLIENT_SECRET | default('') }}

# ============================================
# User Encryption Configuration
# ============================================
USER_ENCRYPTION_KEY={{ app_env_vars.USER_ENCRYPTION_KEY | default('change-me-to-a-secure-key-min-32-chars') }}

# ============================================
# Logging Configuration
# ============================================
LOGGING_SALT={{ app_env_vars.LOGGING_SALT | default('change-me-to-a-random-salt') }}

# ============================================
# Mock Data Mode (for development/staging)
# ============================================
USE_MOCK_DATA={{ app_env_vars.USE_MOCK_DATA | default('false') }}
