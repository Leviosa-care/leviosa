# Vault Configuration for Leviosa {{ app_env | default('production') }}
# Managed by Ansible - DO NOT EDIT MANUALLY

ui = true

listener "tcp" {
  address     = "0.0.0.0:8200"
  tls_disable = "true"
}

# File storage for single-node vault (no raft needed for single VPS)
storage "file" {
  path = "/vault/file/data"
}

# api_addr must be a reachable address for clients
# Use the container name which resolves on Docker networks
api_addr      = "http://{{ app_name }}_vault:8200"
disable_mlock = true
log_level     = "info"
