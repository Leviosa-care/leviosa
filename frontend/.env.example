# =============================================================================
# SvelteKit Frontend Environment Variables
# =============================================================================
# Copy this file to .env and fill in the actual values for your environment.
#
# Environment Variables Usage:
# - Static private ($env/static/private): Variables known at build time
# - Dynamic private ($env/dynamic/private): Variables resolved at runtime
# =============================================================================

# -----------------------------------------------------------------------------
# Application Configuration
# -----------------------------------------------------------------------------

# Node environment (development, staging, production)
# - development: Mock authentication enabled, relaxed security
# - staging: Mock authentication enabled, testing environment
# - production: Real authentication, full security
NODE_ENV="development"

# Backend API base URL
# - Development: Use localhost or backend service name
# - Production: Use your actual backend API domain
API_URL="http://localhost:3400"

# -----------------------------------------------------------------------------
# Session Management
# -----------------------------------------------------------------------------

# Name of the session cookie stored in the user's browser
# Used for authentication and session persistence
SESSION_COOKIE_NAME="leviosa_session"

# -----------------------------------------------------------------------------
# HTTP Headers
# -----------------------------------------------------------------------------

# Header name used to pass the client's IP address through the proxy/reverse proxy
# Common values: X-Forwarded-For, X-Real-IP, CF-Connecting-IP
# The application will attempt to extract the IP from standard headers if this
# header is not present
CLIENT_IP_HEADER="X-Forwarded-For" 
