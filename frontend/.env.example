# =============================================================================
# SvelteKit Frontend Environment Variables
# =============================================================================
# Copy this file to .env and fill in the actual values for your environment.
#
# Environment Variables Usage:
# - Static private ($env/static/private): Variables known at build time
# - Dynamic private ($env/dynamic/private): Variables resolved at runtime
# =============================================================================

# -----------------------------------------------------------------------------
# Application Configuration
# -----------------------------------------------------------------------------

# Node environment (development, staging, production)
# - development: Local development environment
# - staging: Testing environment
# - production: Live production environment
NODE_ENV="development"

# Enable mock authentication mode (requires login with mock credentials below)
# - true: Auth is required but uses mock credentials instead of the real backend
# - false: Use real authentication via API
USE_MOCK_DATA="true"

# Mock credentials (required when USE_MOCK_DATA=true)
# Each pair maps to a role — visitors must log in with one of these to access the app
MOCK_ADMIN_EMAIL="admin@demo.leviosa.fr"
MOCK_ADMIN_PASSWORD="demo-admin"
MOCK_PARTNER_EMAIL="partner@demo.leviosa.fr"
MOCK_PARTNER_PASSWORD="demo-partner"
MOCK_CLIENT_EMAIL="client@demo.leviosa.fr"
MOCK_CLIENT_PASSWORD="demo-client"

# Coming soon mode — redirects all routes to /coming-soon when set to "true"
# Set to "true" on production until the app is ready to launch
# Set to "false" (or omit) on staging to allow normal development
COMING_SOON="false"

# Backend API base URL
# - Development: Use localhost or backend service name
# - Production: Use your actual backend API domain
API_URL="http://localhost:3400"

# -----------------------------------------------------------------------------
# Session Management
# -----------------------------------------------------------------------------

# Name of the session cookie stored in the user's browser
# Used for authentication and session persistence
SESSION_COOKIE_NAME="leviosa_session"

# -----------------------------------------------------------------------------
# HTTP Headers
# -----------------------------------------------------------------------------

# Header name used to pass the client's IP address through the proxy/reverse proxy
# Common values: X-Forwarded-For, X-Real-IP, CF-Connecting-IP
# The application will attempt to extract the IP from standard headers if this
# header is not present
CLIENT_IP_HEADER="X-Forwarded-For" 
