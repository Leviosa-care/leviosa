# Settings Service Configuration Example

# Server Configuration
SERVER_PORT=8080
LOG_LEVEL=info
LOG_STYLE=text

# Database Configuration
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=leviosa
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Redis Configuration  
REDIS_HOST=localhost
REDIS_PORT=6379

# RabbitMQ Configuration
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# Vault Configuration (for service authentication and encryption)
VAULT_ADDR=http://localhost:8200
VAULT_TOKEN=dev-token

# S3/Object Storage Configuration
AWS_ENDPOINT_URL=http://localhost:4566  # For localstack
AWS_DEFAULT_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
S3_BUCKET_NAME=leviosa-settings

# Service Authentication (generated by vault-init)
SERVICE_API_KEY=your-generated-api-key-here